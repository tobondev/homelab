  alloy:
    image: grafana/grafana:latest
    user: "1000"
    volumes:
    - /home/wolf/grafanaloki/alloy:/etc/alloy
    ports:
      - "51423:12345"
    restart: unless-stopped
    networks:
      - loki
  volumes:
  grafana-data:
    driver: local
    restart: unless-stopped
#
  grafana:
    image: grafana/grafana:latest
    user: "1000"
    volumes:
    - /home/wolf/grafanaloki/grafana:/etc/grafana
    ports:
      - "3030:3000"
    restart: unless-stopped
    networks:
      - loki
