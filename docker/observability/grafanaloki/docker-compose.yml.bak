networks:
  loki:
services:
  loki:
    image: grafana/loki:latest
    command: -config.file=/etc/loki/loki-config.yml
    ports:
      - "3131:3100"
    networks:
      - loki
    volumes:
      - ./config/loki-config.yml:/etc/loki/loki-config.yml:ro
      - /home/wolf/grafanaloki/loki:/etc/loki:rw
volumes:
  loki-data:
    driver: local
    restart: unless-stopped

