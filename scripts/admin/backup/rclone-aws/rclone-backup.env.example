# ==============================================================================
# rclone-backup.env.example
# ==============================================================================
# Configuration for rclone_backup.sh and rclone-config.sh.
# Copy to rclone-backup.env, populate values, and add rclone-backup.env
# to .gitignore. The .example file is safe to commit.
#
# Credentials are NOT stored here. They live in the rclone config at
# RCLONE_CONFIG_DIR and are managed separately.
# ==============================================================================

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

# Absolute path to the backup log file.
LOG_FILE="/var/log/rclone_backup.log"

# ------------------------------------------------------------------------------
# BTRFS / Snapshot Configuration
# ------------------------------------------------------------------------------

# Mountpoint used to temporarily mount the snapshot subvolume.
# This directory is created automatically if absent.
SNAPSHOT_MOUNTPOINT="/mountpoint"

# Block device or LVM path containing the BTRFS filesystem.
FILESYSTEM_ROOT="/dev/btrfsroot"

# Name of the BTRFS subvolume that contains the snapshots.
# @btrbk is recommended for readability
SUBVOLUME="@btrbk"

# Glob pattern matched against snapshot directory names.
# This is usually set by btrbk in its configuration file
# If it's not set manually, you can find out what it is by
# browsing the backup directory and use it here.
# By default, btrbk will correctly sort lexicographically in
# chronological order; sort -r is used to fetch the most
# recent snapshot.
SNAPSHOT_PATTERN="pattern.*"

# ------------------------------------------------------------------------------
# Last Known Good Backup (LKGB)
# ------------------------------------------------------------------------------

# Directory inside SNAPSHOT_MOUNTPOINT that holds the LKGB snapshot.
# Lives inside the mounted subvolume so it persists across runs.
# Created automatically after mount if absent.
# Must be a subdirectory of SNAPSHOT_MOUNTPOINT.
LKGB_PATH="${SNAPSHOT_MOUNTPOINT}/LKGB/"

# ------------------------------------------------------------------------------
# rclone Configuration
# ------------------------------------------------------------------------------

# Directory containing the rclone config file (credentials, remotes, etc.).
# Mounted into the Docker container at /config/rclone.
# It is recommended you create your own bind-mount
RCLONE_CONFIG_DIR="/rclone/docker/volume"

# rclone remote destination string, including trailing colon.
# Encryption is handled transparently by the rclone config;
# the remote name reflects this. Change according to rclone.config.
REMOTE_DEST="Encrypted-Storage:"

# Docker image to use for rclone. Pin to a specific tag in production
# to avoid unexpected behaviour from upstream updates. Test before updating.
# Example: rclone/rclone:1.67
RCLONE_IMAGE="rclone/rclone"

# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------

# Temporary file listing changed paths for rclone.
# Written locally and mounted read-only into the rclone container.
# Removed automatically on exit via trap.
DIFF_LIST="/tmp/rclone_diff.txt"
